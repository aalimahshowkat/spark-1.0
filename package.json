{
  "name": "capacity-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"node --env-file=.env server.js\" \"vite\" --names \"proxy,vite\" --prefix-colors \"cyan,magenta\"",
    "server": "node --env-file=.env server.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --environment node"
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "vite": "^5.4.21",
    "vitest": "^4.1.2"
  }
}
