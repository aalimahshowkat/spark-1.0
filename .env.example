# SPARK AI — Environment Variables
# Copy this file to .env and fill in your key
# NEVER commit .env to git

ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# If you're behind corporate TLS inspection and Anthropic requests fail with
# certificate errors, you can enable this for local dev only:
# SPARK_INSECURE_TLS=1

# Optional: require users to login (recommended for any shared deployment).
# If SPARK_LOGIN_PASSWORD is set, auth auto-enables.
# SPARK_AUTH_MODE=password
# SPARK_LOGIN_PASSWORD=change-me

# Optional: store the Anthropic key in macOS Keychain so end users never handle keys.
# Defaults shown here; provision with:
# security add-generic-password -s SPARK_ANTHROPIC_API_KEY -a default -w "sk-ant-..." -U
# SPARK_KEYCHAIN_SERVICE=SPARK_ANTHROPIC_API_KEY
# SPARK_KEYCHAIN_ACCOUNT=default
